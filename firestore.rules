rules_version = '2';

// =====================================================================
// REGLAS DE FIRESTORE — Almacén V&J
// Cómo instalarlas:
//   Firebase Console > Firestore Database > Reglas > pega esto > Publicar
//
// IMPORTANTE: reemplaza ADMIN_EMAIL_AQUI por el mismo correo que pusiste
// en js/firebase-config.js (en minúsculas, exacto).
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn(){
      return request.auth != null;
    }

    function isAdmin(){
      return isSignedIn() && request.auth.token.email.lower() == 'admin_email_aqui';
    }

    function isActive(){
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    // ---- usuarios y solicitudes de acceso ----
    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // un usuario puede editar su propio doc, pero NO puede cambiarse el status/role a sí mismo
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == userId &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.role == resource.data.role
      );
      allow delete: if isAdmin();
    }

    // ---- datos de la empresa y nombre del sistema (para los PDF y el branding) ----
    // lectura pública para poder mostrar el nombre del sistema incluso antes de iniciar sesión
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- inventario ----
    match /products/{doc} {
      allow read, create, update, delete: if isActive();
    }

    // ---- historial de movimientos ----
    match /movements/{doc} {
      allow read, create: if isActive();
      allow update, delete: if isAdmin();
    }
  }
}
